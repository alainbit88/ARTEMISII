{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "telemetry": {
      "title": "Mission Telemetry",
      "description": "Historical telemetry data for Artemis II",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "distanceFromEarth": { "type": "number" },
        "distanceFromMoon": { "type": "number" },
        "velocity": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "coordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        }
      },
      "required": ["userId", "distanceFromEarth", "distanceFromMoon", "velocity", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/telemetry": {
      "schema": "telemetry",
      "description": "Global telemetry logs"
    }
  }
}
